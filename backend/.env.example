# Token bot Discord kamu (Bot, bukan Client Secret)
DISCORD_BOT_TOKEN=

# Dari Discord Developer Portal -> General Information
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# Password buat akses endpoint /api/register-commands (bikin sendiri, string acak)
ADMIN_SECRET=

# Connection string dari MongoDB Atlas (Database > Connect > Drivers)
MONGODB_URI=
# Opsional, default: discord_setup_bot
MONGODB_DB=
